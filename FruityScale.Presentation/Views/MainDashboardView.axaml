<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FruityScale.Presentation.ViewModels"
             xmlns:converters="using:FruityScale.Presentation.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="FruityScale.Presentation.Views.MainDashboardView"
             x:DataType="vm:MainDashboardViewModel"
             Background="#121214">
    
    <UserControl.Resources>
        <converters:NoteNameConverter x:Key="NoteNameConverter"/>
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="FruityScale Dashboard" FontSize="24" FontWeight="SemiBold" Foreground="#F3F4F6"/>
                <TextBlock Text="{Binding DawPath, StringFormat='Active Path: {0}'}" FontSize="12" Foreground="#9CA3AF" TextWrapping="NoWrap"/>
            </StackPanel>
        </Grid>

        <!-- Scan piano roll button -->
        <Button Grid.Row="1" 
                Content="Scan Piano Roll" 
                Command="{Binding ScanNotesCommand}"
                IsEnabled="{Binding !IsScanning}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="16"
                Background="#10B981"
                Foreground="#FFFFFF"
                FontSize="15"
                FontWeight="SemiBold"
                CornerRadius="8"
                Cursor="Hand"
                Margin="0,0,0,20">
            <Button.Styles>
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#059669"/>
                </Style>
            </Button.Styles>
        </Button>

        <!-- Scanning result as scrollable list -->
        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding ScanResults}" 
                 Background="#1E1E22" 
                 CornerRadius="8"
                 BorderBrush="#2D2D34"
                 BorderThickness="1"
                 Padding="8">
            
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListBox.Styles>
            
            <!-- Template for each detected scale result -->
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ScaleMatchItemViewModel">
                    <StackPanel>
                        <Button Command="{Binding ToggleExpandCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="16,12" 
                                Background="#252529" 
                                CornerRadius="6" 
                                BorderBrush="#2D2D34" 
                                BorderThickness="1"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#2A2A30"/>
                                    <Setter Property="BorderBrush" Value="#3D3D44"/>
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#222226"/>
                                </Style>
                            </Button.Styles>
                            
                            <!-- Result summary layout -->
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                
                                <!-- Match score in percentage % -->
                                <Border Grid.Column="0" 
                                        Background="#1A2E26" 
                                        CornerRadius="4" 
                                        Padding="8,4" 
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Result.Score, StringFormat='{}{0:P0}'}" 
                                               FontWeight="Bold" 
                                               FontSize="14" 
                                               Foreground="#34D399"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                
                                <!-- Scale name and root note -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Result.RootNote, Converter={StaticResource NoteNameConverter}}"
                                               FontWeight="Bold" 
                                               FontSize="16"
                                               Foreground="#F3F4F6"/>
                                    <TextBlock Text="{Binding Result.Scale.Name}" 
                                               FontSize="16"
                                               Foreground="#E5E7EB"/>
                                </StackPanel>
                                
                                <!-- Notes out of scale on the right side -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border Background="#2A2A30" 
                                            CornerRadius="4" 
                                            Padding="8,4"
                                            IsVisible="{Binding HasWrongNotes}">
                                        <TextBlock Text="{Binding WrongNotes.Count, StringFormat='Out of Scale: {0}'}" 
                                                   FontSize="12"
                                                   Foreground="#EF4444"/>
                                    </Border>
                                    
                                    <!-- Expand arrow ▼-->
                                    <TextBlock Text="▼" 
                                               FontSize="10" 
                                               Foreground="#6B7280" 
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Expandable detailed analysis -->
                        <Border IsVisible="{Binding IsExpanded}"
                                Background="#1A1A1D"
                                BorderBrush="#2D2D34"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,6,6"
                                Margin="0,-1,0,0"
                                Padding="16">
                            <StackPanel Spacing="14">
                                <!-- Title -->
                                <TextBlock Text="Scale Analysis Details" FontSize="13" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                                
                                <!-- User played notes -->
                                <Grid ColumnDefinitions="160, *">
                                    <TextBlock Grid.Column="0" Text="Your played notes:" FontSize="13" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding UserNotes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="#1E293B" BorderBrush="#1D4ED8" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,2,6,2">
                                                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" Foreground="#93C5FD"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <Border BorderBrush="#222226" BorderThickness="0,0,0,1" Margin="0,4"/>

                                <!-- Missing notes from the detected scale -->
                                <Grid ColumnDefinitions="160, *" IsVisible="{Binding HasMissingNotes}">
                                    <TextBlock Grid.Column="0" Text="Notes you can add:" FontSize="13" Foreground="#F59E0B" VerticalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding MissingNotes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="#2D251A" BorderBrush="#4A3723" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,2,6,2">
                                                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" Foreground="#FDE68A"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                
                                <!-- Notes outside the scale -->
                                <Grid ColumnDefinitions="160, *" IsVisible="{Binding HasWrongNotes}">
                                    <TextBlock Grid.Column="0" Text="Notes outside scale:" FontSize="13" Foreground="#EF4444" VerticalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding WrongNotes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="#2D1A1A" BorderBrush="#4A2323" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,2,6,2">
                                                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" Foreground="#FFCACC"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                
                                <!-- Notes in scale -->
                                <Grid ColumnDefinitions="160, *">
                                    <TextBlock Grid.Column="0" Text="Notes in scale:" FontSize="13" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding ScaleNotes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="#202024" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,2,6,2">
                                                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" Foreground="#E5E7EB"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                
                                <Border BorderBrush="#222226" BorderThickness="0,0,0,1" Margin="0,12,0,12"/>

                                <TextBlock Text="Keyboard Visualization" FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,8"/>

                                <!-- Virtual piano keyboard visualization -->
                                <ItemsControl ItemsSource="{Binding KeyboardVisualization}" HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="0"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    
                                    <!-- Piano key template -->
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PianoKeyViewModel">
                                            <Border Width="32" 
                                                    Height="{Binding KeyHeight}" 
                                                    Background="{Binding BackgroundColor}"
                                                    BorderBrush="{Binding BorderColor}"
                                                    BorderThickness="1"
                                                    CornerRadius="0,0,4,4"
                                                    Margin="1,0,1,0"
                                                    VerticalAlignment="Top">
                                                
                                                <!-- Piano key label -->
                                                <TextBlock Text="{Binding NoteName}" 
                                                           Foreground="{Binding TextColor}" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Bottom" 
                                                           Margin="0,0,0,6"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border BorderBrush="#222226" BorderThickness="0,0,0,1" Margin="0,12,0,12"/>
                                
                                <!-- Perfect match success message -->
                                <Border Background="#14241C" BorderBrush="#1B4332" BorderThickness="1" CornerRadius="4" Padding="10" IsVisible="{Binding !HasWrongNotes}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="✓" Foreground="#34D399" FontWeight="Bold"/>
                                        <TextBlock Text="Perfect match! All captured notes fit this scale beautifully." FontSize="13" Foreground="#34D399"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom status message bar -->
        <Border Grid.Row="3" 
                Background="#1E1E22" 
                CornerRadius="6" 
                Padding="12,8" 
                Margin="0,16,0,0"
                BorderBrush="#2D2D34"
                BorderThickness="1">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="12" 
                       Foreground="#9CA3AF"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>